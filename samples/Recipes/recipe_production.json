{
  "id": "recipe_production",
  "name": "ZROS Production Robot System",
  "description": "Full production configuration with all nodes enabled and strict restart policies",
  "version": "2.0.0",
  "created": "2026-03-11T10:30:00Z",
  "last_modified": "2026-03-11T12:00:00Z",
  "services": [
    {
      "id": "svc_logger",
      "name": "logger_service",
      "display_name": "Logger Service",
      "description": "Central logging service",
      "executable": "ZROS.Services/LoggerService/LoggerService.exe",
      "arguments": ["--level", "Info"],
      "depends_on": [],
      "auto_start": true,
      "start_type": "Automatic",
      "restart_policy": {
        "auto_restart": true,
        "max_retries": 10,
        "initial_delay_ms": 500,
        "backoff_multiplier": 1.5,
        "max_delay_ms": 30000,
        "restart_window_seconds": 120
      },
      "health_check": {
        "enabled": false
      }
    },
    {
      "id": "svc_param_server",
      "name": "param_server",
      "display_name": "Parameter Server",
      "description": "Global parameter server",
      "executable": "ZROS.Services/ParamServer/ParamServer.exe",
      "arguments": ["--port", "8080", "--config", "params.yaml"],
      "depends_on": ["logger_service"],
      "auto_start": true,
      "start_type": "Automatic",
      "restart_policy": {
        "auto_restart": true,
        "max_retries": 5,
        "initial_delay_ms": 1000,
        "backoff_multiplier": 2.0,
        "max_delay_ms": 20000,
        "restart_window_seconds": 60
      },
      "health_check": {
        "enabled": true,
        "interval_seconds": 15,
        "failure_threshold": 2,
        "timeout_seconds": 3,
        "http_endpoint": "http://localhost:8080/health"
      }
    },
    {
      "id": "svc_brain",
      "name": "brain_node",
      "display_name": "Brain Node",
      "description": "Main decision-making node",
      "executable": "ZROS.Services/BrainNode/BrainNode.exe",
      "arguments": [],
      "depends_on": ["logger_service", "param_server"],
      "auto_start": true,
      "start_type": "Automatic",
      "restart_policy": {
        "auto_restart": true,
        "max_retries": 3,
        "initial_delay_ms": 2000,
        "backoff_multiplier": 2.0,
        "max_delay_ms": 30000,
        "restart_window_seconds": 60
      },
      "health_check": {
        "enabled": false
      }
    },
    {
      "id": "svc_sensor",
      "name": "sensor_node",
      "display_name": "Sensor Node",
      "description": "Sensor data acquisition",
      "executable": "ZROS.Services/SensorNode/SensorNode.exe",
      "arguments": ["--rate", "100"],
      "depends_on": ["logger_service", "param_server"],
      "auto_start": true,
      "start_type": "Automatic",
      "restart_policy": {
        "auto_restart": true,
        "max_retries": 5,
        "initial_delay_ms": 1000,
        "backoff_multiplier": 2.0,
        "max_delay_ms": 30000,
        "restart_window_seconds": 120
      },
      "health_check": {
        "enabled": false
      }
    },
    {
      "id": "svc_actuator",
      "name": "actuator_node",
      "display_name": "Actuator Node",
      "description": "Motor and actuator control node",
      "executable": "ZROS.Services/ActuatorNode/ActuatorNode.exe",
      "arguments": [],
      "depends_on": ["logger_service", "param_server", "brain_node"],
      "auto_start": true,
      "start_type": "Automatic",
      "restart_policy": {
        "auto_restart": true,
        "max_retries": 3,
        "initial_delay_ms": 1500,
        "backoff_multiplier": 2.0,
        "max_delay_ms": 20000,
        "restart_window_seconds": 60
      },
      "health_check": {
        "enabled": false
      }
    }
  ]
}
