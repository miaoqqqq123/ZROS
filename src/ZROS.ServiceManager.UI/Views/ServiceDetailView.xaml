<UserControl x:Class="ZROS.ServiceManager.UI.Views.ServiceDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <Border Style="{StaticResource CardStyle}">
        <StackPanel>
            <TextBlock Text="Service Details" Style="{StaticResource SectionHeaderStyle}" FontSize="16"/>

            <!-- Placeholder when nothing is selected -->
            <TextBlock Text="Select a service to view its details."
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontStyle="Italic"
                       Visibility="{Binding HasSelection, Converter={StaticResource InverseBoolToVisibility}}"/>

            <!-- Detail content when a service is selected -->
            <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibilityConverter}}">

                <!-- Status Row -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse Style="{StaticResource StatusIndicatorStyle}"
                             Fill="{Binding ServiceModel.StateColor}"/>
                    <TextBlock Text="{Binding ServiceModel.Name}"
                               FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text=" — " Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0"/>
                    <TextBlock Text="{Binding ServiceModel.StateText}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <!-- Metrics Grid -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="PID:"       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,16,2"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ServiceModel.ProcessId}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Memory:"    Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,16,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ServiceModel.MemoryText}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="CPU:"       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,16,2"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ServiceModel.CpuText}"    Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Restarts:"  Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,16,2"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ServiceModel.RestartCount}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Uptime:"    Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,16,2"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ServiceModel.UptimeText}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                </Grid>

                <!-- Edit Buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="Edit"   Command="{Binding EditCommand}"   Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,4,0"/>
                    <Button Content="Save"   Command="{Binding SaveCommand}"   Style="{StaticResource SuccessButtonStyle}" Margin="0,0,4,0"/>
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource DangerButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
