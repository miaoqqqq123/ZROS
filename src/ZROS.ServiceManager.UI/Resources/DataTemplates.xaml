<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:ZROS.ServiceManager.UI.ViewModels"
                    xmlns:views="clr-namespace:ZROS.ServiceManager.UI.Views">

    <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
        <views:DashboardView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:ServiceListViewModel}">
        <views:ServiceListView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:RecipeManagementViewModel}">
        <views:RecipeManagementView/>
    </DataTemplate>

</ResourceDictionary>
